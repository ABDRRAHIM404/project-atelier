{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-atelier.local/schemas/quality-evidence-v1.json",
  "title": "Project Atelier quality gate evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "generatedAt",
    "commit",
    "environment",
    "owner",
    "tasks",
    "overallResult",
    "checks"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "runId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "commit": { "type": ["string", "null"] },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ci", "node", "platform", "architecture"],
      "properties": {
        "name": { "enum": ["local", "ci"] },
        "ci": { "type": "boolean" },
        "node": { "type": "string" },
        "platform": { "type": "string" },
        "architecture": { "type": "string" }
      }
    },
    "owner": { "type": "string", "minLength": 1 },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Z]+-[0-9]{3}$" }
    },
    "overallResult": { "enum": ["passed", "failed"] },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/check" }
    }
  },
  "$defs": {
    "exception": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "reason", "approvedBy", "expiresAt", "compensatingControls"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "approvedBy": { "type": "string", "minLength": 1 },
        "expiresAt": { "type": "string", "format": "date-time" },
        "compensatingControls": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "taskIds",
        "requirementIds",
        "command",
        "result",
        "startedAt",
        "finishedAt",
        "durationMs",
        "exitCode",
        "artifacts",
        "exception"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "taskIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[A-Z]+-[0-9]{3}$" }
        },
        "requirementIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "command": { "type": "string", "minLength": 1 },
        "result": { "enum": ["passed", "failed", "not-run"] },
        "startedAt": { "type": ["string", "null"], "format": "date-time" },
        "finishedAt": { "type": ["string", "null"], "format": "date-time" },
        "durationMs": { "type": ["integer", "null"], "minimum": 0 },
        "exitCode": { "type": ["integer", "null"] },
        "artifacts": { "type": "array", "items": { "type": "string" } },
        "exception": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/exception" }]
        }
      }
    }
  }
}
