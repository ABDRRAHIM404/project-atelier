# Technical runtime only. Business policy values do not belong in this file.
APP_ENV=development

# Server-only P1 adapters. Leave blank until configuring an authorized environment.
DATABASE_URL=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Keep false until the private S3 upload/finalize/scan path is configured and verified.
PRIVATE_UPLOADS_READY=false

# Local demo only. Never enable in staging or production.
ALLOW_DEMO_AUTH=false
